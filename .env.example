# .env.example

# Alterdata API configuration
ALTERDATA_API_URL=https://api.alterdata.com/v1/sync
ALTERDATA_TOKEN=your_alterdata_token_here

# SMTP configuration for email notifications
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_email@example.com
SMTP_PASS=your_email_password

# Folder to watch for exported notes (relative to project root)
NOTES_EXPORT_FOLDER=notas_exportadas
