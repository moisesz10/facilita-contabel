# .env

# Alterdata API configuration
ALTERDATA_API_URL=https://api.alterdata.com/v1/sync
ALTERDATA_TOKEN=example_token_123

# SMTP configuration for email notifications
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=example_user@gmail.com
SMTP_PASS=example_password

# Notification email receiver
NOTIFICATION_EMAIL=example_user@gmail.com

# Folder to watch for exported notes (relative to project root)
NOTES_EXPORT_FOLDER=notas_exportadas

PORT=4000
